# Copy this file to .env and fill in your values.
# The .env file must be placed in the project root (the directory that contains public/ and src/).

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=yealinkcalllog
DB_USER=yealink
DB_PASS=strongpassword

# ── Yealink ingest token (optional) ──────────────────────────────────────────
# If set, every /yealink/event request must include ?token=<value>.
# Leave blank (or remove the line) to disable token checking.
YEALINK_TOKEN=

# ── Session secret (optional, recommended) ────────────────────────────────────
# Used to make PHP session IDs harder to guess.
# Generate with: php -r "echo bin2hex(random_bytes(32));"
SESSION_SECRET=
